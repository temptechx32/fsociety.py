#!/bin/bash

echo "================ TECHX-FETCH ================"

# USER
echo "User: $USER"

# MAC-Adresse (erste aktive Schnittstelle)
MAC=$(ip link show 2>/dev/null | awk '/ether/ {print $2; exit}')
echo "MAC: $MAC"

# Distro
if [ -f /etc/os-release ]; then
    DISTRO=$(grep '^PRETTY_NAME=' /etc/os-release | cut -d= -f2 | tr -d '"')
else
    DISTRO="Unknown"
fi
echo "Distro: $DISTRO"

# VM / Virtualisierung
if command -v systemd-detect-virt >/dev/null 2>&1; then
    VM=$(systemd-detect-virt)
else
    VM="unknown"
fi
echo "VM: $VM"

# Desktop Environment
DE=${XDG_CURRENT_DESKTOP:-$DESKTOP_SESSION}
echo "DE: $DE"

echo "============================================="